# ─── Supabase ───────────────────────────────────────────────
# Obtenés estos valores en: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google OAuth ────────────────────────────────────────────
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── NextAuth ────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Anthropic ───────────────────────────────────────────────
# Obtener en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google APIs (Calendar + Drive) ──────────────────────────
# Mismo proyecto de Google Cloud, habilitar: Google Calendar API, Google Drive API
# Scopes necesarios: calendar.events, drive.file
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.events
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.file

# ─── Resend (emails) ─────────────────────────────────────────
# Crear cuenta gratis en: https://resend.com → API Keys
# Plan gratuito: 3000 emails/mes
RESEND_API_KEY=re_...
# Email verificado en Resend desde donde se envían los recordatorios
RESEND_FROM_EMAIL=recordatorios@tu-dominio.com
# URL pública de la app (para links en el email)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Clave para proteger el cron job — cualquier string largo
CRON_SECRET=mi-clave-secreta-larga-para-el-cron
